    "💡 Die Nachricht wurde basierend auf Alter, Meilenstein und Sternzeichen personalisiert.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "💡 The message was personalized based on age, milestone, and zodiac sign."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "💡 El mensaje fue personalizado en función de la edad, el hito y el signo zodiacal."
