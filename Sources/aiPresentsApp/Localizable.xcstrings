        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La IA recibe tu nombre de pila y datos anonimizados como grupo de edad y género. Tu apellido y fecha de nacimiento permanecen en el dispositivo."
          }
        }
      }
