        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app does not collect any data about you and sends nothing to us. All your birthdays and gift ideas stay on your device (or optionally in your iCloud)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app no recopila ningún dato tuyo y no nos envía nada. Todos tus cumpleaños e ideas de regalo permanecen en tu dispositivo (u opcionalmente en tu iCloud)."
          }
        },
        "fr": {
          "stringUnit": {
