    "Alle gespeicherten Daten dieser App werden unwiderruflich gelöscht. Deine Kontakte, Kalendereinträge und andere Apps bleiben vollständig unberührt.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All stored data of this app will be permanently deleted. Your contacts, calendar entries, and other apps remain completely unaffected."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toutes les données de cette app seront définitivement supprimées. Vos contacts, entrées de calendrier et autres apps restent totalement intacts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos los datos almacenados de esta app se eliminarán permanentemente. Tus contactos, entradas de calendario y otras apps permanecen completamente sin cambios."
          }
        }
      }
    },
