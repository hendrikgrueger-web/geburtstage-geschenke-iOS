    "NSContactsUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese App benötigt Zugriff auf deine Kontakte, um Geburtstage von Freunden und Familie zu importieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app needs access to your contacts to import birthdays of friends and family."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette app a besoin d'accéder à vos contacts pour importer les anniversaires de vos amis et de votre famille."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app necesita acceso a tus contactos para importar los cumpleaños de amigos y familiares."
          }
        }
      }
    },
    "NSUserNotificationsUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese App möchte dich an Geburtstage erinnern, damit du pünktlich Geschenke vorbereiten kannst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app would like to remind you about birthdays so you can prepare gifts on time."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette app souhaite vous rappeler les anniversaires afin que vous puissiez préparer les cadeaux à temps."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app desea recordarte los cumpleaños para que puedas preparar regalos a tiempo."
          }
        }
      }
    },
    "NSUbiquitousContainersUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese App nutzt iCloud, um deine Daten zwischen deinen Apple-Geräten zu synchronisieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app uses iCloud to sync your data across your Apple devices."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette app utilise iCloud pour synchroniser vos données entre vos appareils Apple."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app utiliza iCloud para sincronizar tus datos entre tus dispositivos Apple."
          }
        }
      }
    },
    "NSMicrophoneUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese App benötigt Zugriff auf das Mikrofon für die Spracheingabe im KI-Chat."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app needs microphone access for voice input in the AI chat."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette app a besoin d'accéder au microphone pour la saisie vocale dans le chat IA."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app necesita acceso al micrófono para la entrada de voz en el chat de IA."
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese App nutzt Spracherkennung, um deine Spracheingaben im KI-Chat in Text umzuwandeln."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app uses speech recognition to convert your voice input into text in the AI chat."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette app utilise la reconnaissance vocale pour convertir vos entrées vocales en texte dans le chat IA."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app utiliza reconocimiento de voz para convertir tu entrada de voz en texto en el chat de IA."
          }
        }
      }
    },
    "NSFaceIDUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese App nutzt Face ID zum Schutz deiner persönlichen Daten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app uses Face ID to protect your personal data."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette app utilise Face ID pour protéger vos données personnelles."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app utiliza Face ID para proteger tus datos personales."
          }
        }
      }
    }
  },
  "version": "1.0"
}
